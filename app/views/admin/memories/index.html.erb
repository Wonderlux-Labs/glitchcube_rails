<% content_for :layout, 'admin' %>

<h1>🧠 Memories</h1>

<div style="margin-bottom: 20px;">
  <%= link_to 'All', admin_memories_path, class: 'btn' %>
  <% (@categories || Memory::CATEGORIES).each do |category| %>
    <%= link_to "#{category.humanize} (#{(@category_counts || {})[category] || 0})",
        by_category_admin_memories_path(category: category), class: 'btn' %>
  <% end %>
</div>

<div style="margin-bottom: 20px;">
  <%= form_with url: search_admin_memories_path, method: :get, local: true do |f| %>
    <%= f.text_field :q, placeholder: 'Search memories...', value: params[:q] %>
    <%= f.submit 'Search', class: 'btn' %>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th>Category</th>
      <th>Content</th>
      <th>Importance</th>
      <th>Emotion</th>
      <th>Occurs At</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @memories.each do |memory| %>
      <tr>
        <td><%= memory.category&.humanize %></td>
        <td><%= memory.content.truncate(100) %></td>
        <td>
          <span style="color: <%= memory.importance >= 7 ? '#00ff00' : memory.importance >= 4 ? '#ffff00' : '#666' %>">
            <%= memory.importance %>/10
          </span>
        </td>
        <td><%= memory.emotion %></td>
        <td><%= memory.occurs_at&.strftime('%m/%d %H:%M') %></td>
        <td><%= memory.created_at.strftime('%m/%d %H:%M') %></td>
        <td>
          <%= link_to 'View', admin_memory_path(memory), class: 'btn' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @memories.empty? %>
  <p style="color: #666; text-align: center; margin: 40px 0;">
    No memories found.
  </p>
<% end %>
