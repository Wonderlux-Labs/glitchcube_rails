<% content_for :layout, 'admin' %>

<h1>💬 Conversation Details</h1>

<div style="margin-bottom: 20px;">
  <%= link_to '← Back to Conversations', admin_conversations_path, class: 'btn' %>
</div>

<div class="stats">
  <div class="stat-box">
    <h3>📋 Overview</h3>
    <p><strong>Session ID:</strong> <%= @conversation.session_id %></p>
    <p><strong>Persona:</strong> <%= @conversation.persona %></p>
    <p><strong>Status:</strong>
      <span class="<%= @conversation.active? ? 'active-status' : 'finished-status' %>">
        <%= @conversation.active? ? 'Active' : 'Finished' %>
      </span>
    </p>
    <p><strong>Started:</strong> <%= @conversation.started_at %></p>
    <% if @conversation.ended_at %>
      <p><strong>Ended:</strong> <%= @conversation.ended_at %></p>
      <p><strong>Duration:</strong> <%= @conversation.duration&.round(2) %>s</p>
    <% end %>
  </div>

  <div class="stat-box">
    <h3>📊 Stats</h3>
    <p><strong>Messages:</strong> <%= @logs.count %></p>
    <p><strong>Total Tokens:</strong> <%= @conversation.total_tokens %></p>
    <p><strong>Total Cost:</strong> $<%= @conversation.total_cost %></p>
  </div>
</div>

<h2>💬 Conversation Flow</h2>
<p style="color: #666;">Turns and the HASS action-agent's results for this conversation, interleaved by timestamp (best-effort — reload to refresh, this page doesn't auto-update).</p>

<% turn_number = 0 %>
<% @timeline.each do |event| %>
  <% if event[:type] == :turn %>
    <% turn_number += 1 %>
    <% log = event[:log] %>
    <div style="background: #2a2a2a; padding: 15px; margin: 10px 0; border-left: 3px solid #00ff00;">
      <p><strong>Turn #<%= turn_number %></strong> - <%= log.created_at.strftime('%H:%M:%S') %>
        <% if log.usage.present? %>
          <span style="color: #666; font-size: 0.85em;">
            (<%= log.usage['model'] %> · <%= log.usage['total_tokens'] %> tokens · $<%= log.usage['cost'] %>)
          </span>
        <% end %>
      </p>

      <div style="background: #1a1a1a; padding: 10px; margin: 5px 0;">
        <p><strong>👤 User:</strong></p>
        <p><%= log.user_message %></p>
      </div>

      <div style="background: #1a1a1a; padding: 10px; margin: 5px 0;">
        <p><strong>🤖 AI:</strong></p>
        <p><%= log.ai_response %></p>
      </div>

      <% narrative = log.metadata_json["narrative"] %>
      <% if narrative.present? %>
        <% if narrative["ooc_questions"].present? %>
          <div style="background: #4a3a00; padding: 10px; margin: 5px 0; border-left: 3px solid #ffcc00;">
            <p><strong>🎬 ooc_questions:</strong> <%= narrative["ooc_questions"] %></p>
          </div>
        <% end %>
        <details style="background: #333; padding: 10px; margin: 5px 0;">
          <summary style="cursor: pointer;"><strong>🧠 Full brain narrative</strong></summary>
          <pre><%= JSON.pretty_generate(narrative) %></pre>
        </details>
      <% end %>
    </div>
  <% else %>
    <% result = event[:result] %>
    <div style="background: #1a2a33; padding: 15px; margin: 10px 0; border-left: 3px solid #00ccff;">
      <p><strong>🏠 Action agent result</strong> - <%= event[:timestamp]&.strftime('%H:%M:%S') %></p>
      <p><strong>Instruction:</strong> <%= result['instruction'] %></p>
      <% if result['error'].present? %>
        <p style="color: #ff6666;"><strong>Error:</strong> <%= result['error'] %></p>
      <% else %>
        <p><strong>Result:</strong> <%= result['ha_response'] %></p>
      <% end %>
      <% if result['tool_calls'].present? || result['service_calls'].present? %>
        <details style="background: #16242b; padding: 8px; margin: 6px 0;">
          <summary style="cursor: pointer;"><strong>🔧 Tool &amp; service calls that fired</strong></summary>
          <pre><%= JSON.pretty_generate("tool_calls" => result["tool_calls"] || [], "service_calls" => result["service_calls"] || []) %></pre>
        </details>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if @timeline.empty? %>
  <p style="color: #666;">No turns or action results yet.</p>
<% end %>
