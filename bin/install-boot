#!/bin/bash
# Install (or reinstall) the GlitchCube boot supervisor LaunchAgent.
# Run once on bigbuddy from the logged-in GUI session:  bin/install-boot
set -euo pipefail

APP_ROOT="/Users/estiens/code/glitchcube-main/glitchcube_rails"
LABEL="com.glitchcube.boot"
SRC="$APP_ROOT/deploy/launchd/$LABEL.plist"
DST="$HOME/Library/LaunchAgents/$LABEL.plist"
DOMAIN="gui/$(id -u)"

[ -f "$SRC" ] || { echo "missing $SRC"; exit 1; }

mkdir -p "$HOME/Library/LaunchAgents"
cp "$SRC" "$DST"
echo "installed $DST"

# Replace any existing instance (modern launchctl API).
launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
launchctl bootstrap "$DOMAIN" "$DST"
echo "bootstrapped $DOMAIN/$LABEL"

# --- Squeezelite (KeepAlive audio player) -------------------------------------
# Supervise Squeezelite with launchd so it restarts on crash, replacing the old
# "Squeezelite" Login Item (no crash recovery). This stops the currently running
# Squeezelite and hands it to launchd, so audio blips for a second here.
SQ_LABEL="com.glitchcube.squeezelite"
SQ_SRC="$APP_ROOT/deploy/launchd/$SQ_LABEL.plist"
SQ_DST="$HOME/Library/LaunchAgents/$SQ_LABEL.plist"

if [ -f "$SQ_SRC" ]; then
  echo
  mkdir -p "$HOME/Library/Logs"
  cp "$SQ_SRC" "$SQ_DST"
  echo "installed $SQ_DST"

  # Drop the Login Item so the app isn't double-launched alongside the agent.
  if osascript -e 'tell application "System Events" to delete login item "Squeezelite"' 2>/dev/null; then
    echo "removed 'Squeezelite' Login Item"
  else
    echo "no 'Squeezelite' Login Item to remove (ok)"
  fi

  # Kill any Squeezelite from the Login Item so the agent owns the single instance.
  if pkill -x Squeezelite 2>/dev/null; then echo "stopped existing Squeezelite"; sleep 1; fi

  launchctl bootout "$DOMAIN/$SQ_LABEL" 2>/dev/null || true
  launchctl bootstrap "$DOMAIN" "$SQ_DST"
  echo "bootstrapped $DOMAIN/$SQ_LABEL (KeepAlive — restarts on crash)"
else
  echo "skip squeezelite: $SQ_SRC not found"
fi
# ------------------------------------------------------------------------------

cat <<EOF

Done. Installed two LaunchAgents:
  - $LABEL (boot supervisor): starts VM + Rails at login/power-cycle AND
    auto-restarts the whole stack on crash (KeepAlive). To take it down for
    maintenance use 'bin/glitchcube-ctl stop' (bootout) — a plain kill just gets
    resurrected. It still starts on the next reboot (RunAtLoad).
  - $SQ_LABEL (Squeezelite): KeepAlive, so audio restarts on crash.

Control the boot supervisor with:  bin/glitchcube-ctl {start|stop|restart|status|logs}

Before relying on unattended power-outage recovery, confirm:
  1. Auto-login is ON for 'estiens' (System Settings > Users & Groups).
  2. Ruby $(cat "$APP_ROOT/.ruby-version") is installed:  rbenv versions
  3. The UTM VM name is 'glitch':  /Applications/UTM.app/Contents/MacOS/utmctl list
     (if different, update VM_NAME in bin/ensure-hass-vm)

Useful commands:
  bin/glitchcube-ctl status                 # both agents + support services
  bin/glitchcube-ctl restart                # restart the boot supervisor now
  bin/glitchcube-ctl logs                   # watch supervisor logs
  launchctl bootout $DOMAIN/$LABEL          # uninstall the boot supervisor
  launchctl bootout $DOMAIN/$SQ_LABEL       # uninstall the squeezelite agent
EOF
