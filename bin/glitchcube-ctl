#!/bin/bash
# Control the GlitchCube boot supervisor (com.glitchcube.boot LaunchAgent).
#
# The agent has KeepAlive=false: stopping it stays stopped, but the job remains
# loaded so RunAtLoad still fires on the next power-cycle. Use these during dev.
#
#   bin/glitchcube-ctl start     # run it now (VM + Rails + jobs)
#   bin/glitchcube-ctl stop      # stop it, stays stopped until you start / reboot
#   bin/glitchcube-ctl restart   # stop + start
#   bin/glitchcube-ctl status    # launchd state + last exit code
#   bin/glitchcube-ctl logs      # tail the supervisor logs
#   bin/glitchcube-ctl unload    # remove it from launchd entirely (no RunAtLoad on
#                                # reboot). Re-add with: bin/install-boot
set -euo pipefail

APP_ROOT="/Users/estiens/code/glitchcube-main/glitchcube_rails"
LABEL="com.glitchcube.boot"
TARGET="gui/$(id -u)/$LABEL"

case "${1:-}" in
  start)
    # kickstart if already loaded; otherwise bootstrap from the installed plist.
    launchctl kickstart "$TARGET" 2>/dev/null \
      || launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/$LABEL.plist"
    ;;
  stop)
    launchctl kill TERM "$TARGET"
    ;;
  restart)
    # Graceful: TERM the supervisor so foreman forwards it to Puma + jobs and
    # SolidQueue deregisters cleanly, wait for it to exit, THEN start fresh.
    # (kickstart -k SIGKILLs the whole tree — that orphans jobs and can leave two
    # SolidQueue supervisors overlapping on the next start.)
    launchctl kill TERM "$TARGET" 2>/dev/null || true
    for _ in $(seq 1 30); do
      launchctl print "$TARGET" 2>/dev/null | grep -q 'state = running' || break
      sleep 1
    done
    launchctl kickstart "$TARGET"
    ;;
  status)
    echo "--- boot supervisor ($LABEL) ---"
    launchctl print "$TARGET" 2>/dev/null | grep -E 'state|last exit|pid|program' \
      || echo "not installed (run bin/install-boot)"
    echo "--- squeezelite agent (com.glitchcube.squeezelite) ---"
    launchctl print "gui/$(id -u)/com.glitchcube.squeezelite" 2>/dev/null \
      | grep -E 'state|last exit|pid' || echo "not installed (still a Login Item?)"
    echo "--- support services ---"
    "$APP_ROOT/bin/check-services"
    ;;
  logs)
    tail -f "$APP_ROOT/log/boot.out.log" "$APP_ROOT/log/boot.err.log"
    ;;
  unload)
    # Fully remove the boot supervisor from launchd (stops it AND clears the job,
    # so it will NOT start on the next login/reboot). Re-add with bin/install-boot.
    # Leaves the squeezelite agent alone. bootout also delivers SIGTERM, so foreman
    # + Puma + SolidQueue shut down cleanly on the way out.
    if launchctl bootout "$TARGET" 2>/dev/null; then
      echo "unloaded $LABEL (re-add with: bin/install-boot)"
    else
      echo "$LABEL was not loaded"
    fi
    ;;
  *)
    echo "usage: bin/glitchcube-ctl {start|stop|restart|status|logs|unload}" >&2
    exit 1
    ;;
esac
